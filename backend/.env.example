# PostgreSQL connection string (Railway/Render provide this)
DATABASE_URL="postgresql://postgres@localhost:5432/finance_tracker?schema=public"

# JWT secret - use a strong random string in production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server port
PORT=5000

# Frontend URL for CORS (Vercel deployment URL)
FRONTEND_URL="http://localhost:5173"
